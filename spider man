<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <title>WebXR Spider-Man: Infinite City</title>
    <script src="https://aframe.io/releases/1.4.0/aframe.min.js"></script>
    <script src="https://cdn.jsdelivr.net/gh/donmccurdy/aframe-extras@v6.1.1/dist/aframe-extras.min.js"></script>
  </head>
  <body>
    <a-scene environment="preset: midnight; dressingAmount: 0">
      
      <a-entity id="rig" position="0 15 0">
        <a-entity id="camera" camera look-controls position="0 1.6 0"></a-entity>
        <a-entity id="right-hand" oculus-touch-controls="hand: right" 
                  raycaster="objects: .building, .suit; far: 100" 
                  line="color: red; opacity: 0.5"></a-entity>
      </a-entity>

      <a-entity id="apartment" position="0 15 0">
        <a-box position="0 -0.1 0" width="10" height="0.2" depth="10" color="#442200"></a-box> <a-box position="0 4 0" width="10" height="0.2" depth="10" color="#333"></a-box> <a-box position="-5 2 0" width="0.2" height="4" depth="10" color="#555"></a-box> <a-box position="5 2 0" width="0.2" height="4" depth="10" color="#555"></a-box> <a-box position="0 2 5" width="10" height="4" depth="0.2" color="#555"></a-box> <a-box id="suit" class="suit" position="2 1 -2" width="0.6" height="0.1" depth="0.6" color="red"
               animation="property: rotation; to: 0 360 0; loop: true; dur: 4000"></a-box>
        <a-text value="GET SUIT" position="1.6 1.5 -2" color="white" width="4"></a-text>
      </a-entity>
